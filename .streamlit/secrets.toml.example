# MedBuddy — Streamlit secrets template
#
# LOCAL DEV:  copy this file to ".streamlit/secrets.toml" and fill in your key
#             (that real file is gitignored). The .env file also works locally.
# CLOUD:      do NOT commit a real secrets.toml. Instead paste these values into
#             Streamlit Community Cloud → App → Settings → Secrets.
#
# Streamlit also exposes top-level secrets as environment variables, so the
# existing os.getenv("GROQ_API_KEY") in config/settings.py picks this up.

GROQ_API_KEY = "your_groq_api_key_here"

# Optional overrides (defaults are set in config/settings.py):
# PRIMARY_MODEL = "llama-3.3-70b-versatile"
# FALLBACK_MODEL = "llama3-70b-8192"
